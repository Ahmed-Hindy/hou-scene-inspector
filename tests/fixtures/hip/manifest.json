{
  "houdini_version": "21.0.631",
  "runtime_rule": "Fixtures may be generated with Houdini; hip_reader runtime must remain Houdini-free.",
  "fixtures": {
    "empty.hip": {
      "purpose": "Baseline empty scene.",
      "contents": "No user-created operator nodes.",
      "expected": ["CPIO records", "global metadata", "zero inspected nodes"]
    },
    "one_geo_node.hip": {
      "purpose": "Single object-level geometry node.",
      "contents": "/obj/geo1 without child SOPs.",
      "expected": ["/obj/geo1 type geo"]
    },
    "one_geo_with_box.hip": {
      "purpose": "Nested SOP hierarchy and basic parameters.",
      "contents": "/obj/geo1/box1.",
      "expected": ["box size parm", "geo spareparmdef", "channel references"]
    },
    "box_wired_xform.hip": {
      "purpose": "Single SOP connection.",
      "contents": "/obj/geo1/box1 -> /obj/geo1/transform1.",
      "expected": ["input connection in transform1.def", "obj/geo1.order"]
    },
    "two_geo_nodes.hip": {
      "purpose": "Multiple top-level object nodes.",
      "contents": "/obj/geo1 and /obj/geo2.",
      "expected": ["two /obj children"]
    },
    "renamed_node.hip": {
      "purpose": "Non-default node name.",
      "contents": "/obj/myGeo.",
      "expected": ["renamed object path"]
    },
    "nested_subnet.hip": {
      "purpose": "Arbitrary nested network path handling.",
      "contents": "/obj/geo1/subnet1/box1.",
      "expected": ["recursive hierarchy"]
    },
    "merge_two_boxes.hip": {
      "purpose": "Multi-input fan-in connection block.",
      "contents": "box1 and box2 connected to merge1.",
      "expected": ["two resolved input edges"]
    },
    "fanout_box_to_two_xforms.hip": {
      "purpose": "Fan-out connection graph.",
      "contents": "box1 connected to xform1 and xform2.",
      "expected": ["two downstream edges from one source"]
    },
    "bypass_template_flags.hip": {
      "purpose": "Known display/render/template/bypass flags.",
      "contents": "templated box and bypassed xform.",
      "expected": ["parsed flag states"]
    },
    "parm_changed_transform.hip": {
      "purpose": "Known static vector parameter values.",
      "contents": "xform translate, rotate, scale changed.",
      "expected": ["typed parm values"]
    },
    "string_expression_parm.hip": {
      "purpose": "String parameter containing quotes and parentheses.",
      "contents": "Custom spare string parm with Python expression text.",
      "expected": ["no truncation"]
    },
    "animated_translate.hip": {
      "purpose": "Keyframed channel segments.",
      "contents": "xform1 tx keyed at frames 1 and 24.",
      "expected": ["tx channel segments"]
    },
    "expression_driven_parm.hip": {
      "purpose": "Expression-only channel.",
      "contents": "xform1 tx expression $F * 2.",
      "expected": ["tx expression segment"]
    },
    "mixed_static_animated.hip": {
      "purpose": "Static, animated, and expression-driven parms together.",
      "contents": "xform1 tx keyed, ty static, tz expression.",
      "expected": ["mixed channel and parm states"]
    },
    "custom_spare_parms.hip": {
      "purpose": "Custom spare parameter template grammar.",
      "contents": "Custom folder with int, float, string, toggle, and menu parms.",
      "expected": ["template names, labels, defaults"]
    },
    "userdata_string_int_float.hip": {
      "purpose": "Controlled saved userdata strings.",
      "contents": "string_value, int_value, float_value user data.",
      "expected": ["userdata dictionary entries"]
    },
    "locked_geometry_or_stash.hip": {
      "purpose": "Binary payload discovery.",
      "contents": "Hard-locked box SOP.",
      "expected": ["obj/geo1/box1.data binary record"]
    },
    "rop_and_materials.hip": {
      "purpose": "Non-/obj contexts.",
      "contents": "/out/geometry1 and /mat/principledshader1.",
      "expected": ["out and mat context nodes"]
    },
    "subnet_inside_geo.hip": {
      "purpose": "Recursive subnet with an internal connection.",
      "contents": "/obj/geo1/subnet1/box1 -> xform1.",
      "expected": ["deep resolved connection"]
    },
    "simple_hda_instance.hip": {
      "purpose": "Minimal HDA instance metadata.",
      "contents": "/obj/simple_hda1 type hip_reader_simple_hda::1.0 with an exposed inner_geo child record and companion simple_hda_definition.hda.",
      "expected": ["HDA node type", ".OPlibraries reference", "marker userdata"]
    },
    "two_takes_changed_parm.hip": {
      "purpose": "Take hierarchy and take-specific parm payload.",
      "contents": "Main take with child Alt take changing xform tx.",
      "expected": ["Main and Alt take names"]
    }
  }
}
